    <target depends="init,compile" if="have.tests" name="-pre-test-run">
        <mkdir dir="${build.test.results.dir}"/>
    </target>
    <target depends="init,compile,compile-test,-pre-test-run" if="have.tests" name="-do-test-run">
        <j2seproject3:test testincludes="**/*Test.java"/>
    </target>
    <target name="-post-test-run">
